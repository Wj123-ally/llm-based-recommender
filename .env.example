# =============================================================================
# 中文服装推荐系统 — 环境变量配置模板
# 复制此文件为 .env 并填入实际值
#   cp .env.example .env
# =============================================================================

# ---------- 必填：DashScope API Key ----------
# 从 https://dashscope.aliyun.com/ 获取
DASHSCOPE_API_KEY=sk-your-api-key-here

# ---------- DashScope 模型配置 ----------
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# ---------- Cross-Encoder 重排模型 ----------
# 可选值: BAAI/bge-reranker-base, BAAI/bge-reranker-large, BAAI/bge-reranker-v2-m3
CROSS_ENCODER_MODEL_NAME=BAAI/bge-reranker-base

# ---------- Milvus 向量检索配置 ----------
# Docker 内部使用 http://milvus:19530（容器名）；本地开发使用 http://localhost:19530
MILVUS_URI=http://localhost:19530
MILVUS_TEXT_COLLECTION_NAME=product_collection
MILVUS_IMAGE_COLLECTION_NAME=product_image_collection
MILVUS_KNOWLEDGE_COLLECTION_NAME=knowledge_base_collection
DENSE_RETRIEVER_TOP_K=20
DENSE_SIMILARITY_THRESHOLD=0.2
# Milvus 端口映射（仅本地 Docker 部署时生效）
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
# MinIO 认证（Milvus 对象存储）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------- BM25 关键词检索配置 ----------
BM25_RETRIEVER_TOP_K=20
BM25_MIN_SCORE=0

# ---------- CLIP 多模态检索 ----------
# false = 允许联网下载 CLIP 模型；下载后可改回 true
CLIP_LOCAL_FILES_ONLY=false
ENABLE_MULTIMODAL_RETRIEVER=true

# ---------- RRF 融合 & 重排配置 ----------
RERANK_TOP_N=5
RRF_K=60

# ---------- Streamlit UI 后端地址 ----------
# Docker 内部使用 http://api:8000，本地开发使用 http://localhost:8000
API_URL=http://localhost:8000

# ---------- 可选：首次启动行为 ----------
# 设为 true 则在容器首次启动时自动下载数据并构建索引（耗时且消耗 API 额度）
BOOTSTRAP=false
